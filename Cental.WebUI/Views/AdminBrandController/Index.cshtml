@using PagedList.Core
@model PagedList<Brand>
@{
    ViewData["Title"] = "Markalar";
    Layout = "~/Views/AdminLayout/Layout.cshtml";
}

@{
    int count = Model.PageCount * Model.PageNumber - (Model.PageSize - 1);
}

<table class="table table-bordered"> 
    <tr>
        <th>#</th>
        <th>Marka</th>
        <th>Sil</th>
        <th>Güncelle</th>
    </tr>
    @foreach (var item in Model)
    {
        count++;
        <tr>
            <td>@count</td>
            <td>@item.BrandName</td>

            <td><a asp-action="DeleteBrand" asp-route-id="@item.BrandId" class="btn btn-danger"><i class="fa fa-trash"></i></a> </td>
            <td><a asp-action="UpdateBrand" asp-route-id="@item.BrandId" class="btn btn-info"><i class="fa fa-pen"></i></a> </td>
        </tr>
        
    }
    
</table>
<div class="text-center">
    <pager asp-action="Index" asp-controller="AdminBrandController" list="@Model"></pager>  @*  Sayfalama *@
</div>

<a asp-action="CreateBrand" asp-controller="AdminBrandController" class="btn btn-primary">Yeni Marka Ekle</a>



